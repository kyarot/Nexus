# App
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
JWT_SECRET_KEY=replace-with-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=1440

# Firebase
# Path to your Firebase Admin SDK service account JSON.
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json
# Optional. Needed only if using Firebase Realtime Database.
FIREBASE_DATABASE_URL=

# Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Google Cloud Storage
# Name of your GCS bucket.
GCS_BUCKET_NAME=your-gcs-bucket-name
# Path to your GCP service account JSON for Storage and other GCP clients.
# If empty, default application credentials are used.
GCP_SERVICE_ACCOUNT_PATH=./secrets/gcp-service-account.json
